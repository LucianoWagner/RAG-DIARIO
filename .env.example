# Groq
GROQ_API_KEY=tu_api_key_aqui

# Models
LLM_MODEL=llama3.1:8b
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=intfloat/multilingual-e5-large
GEMINI_API_KEY=tu_gemini_api_key_aqui

# Scope classifier
SCOPE_EMBEDDING_THRESHOLD=0.15
SCOPE_LLM_MODEL=qwen2.5:3b-instruct
SCOPE_LLM_ENABLED=true

# Ports
OLLAMA_PORT=11434
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
BACKEND_PORT=8080
WEBUI_PORT=3000

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=hemeroteca_la_plata

# Chunking
CHUNK_SIZE=900
CHUNK_OVERLAP=120

# Retrieval
TOP_K=20
RERANK_TOP_N=8
SEMANTIC_WEIGHT=0.5
BM25_WEIGHT=0.5

# Evidence
MIN_TOP_SCORE=0.3
MIN_RELEVANT_CHUNKS=2
RELEVANCE_THRESHOLD=0.25

# Scraping
SCRAPER_USER_AGENT=HemerotecaLaPlataAcademic/1.0
SCRAPER_RATE_LIMIT_SECONDS=2
SCRAPER_TARGET_YEAR=2005
SCRAPER_MAX_DAYS=7
SCRAPER_DISCOVERY_MODE=auto
SCRAPER_SEARCH_TERMS=La Plata
SCRAPER_MAX_SEARCH_PAGES=3
